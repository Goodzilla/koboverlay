# Server Port
PORT=4000

# Database Connection (SQLite default, or PostgreSQL for cloud)
DATABASE_URL="file:./dev.db"

# JWT Authentication Secret — use a long random string in production
JWT_SECRET="change_this_to_a_long_random_secret"

# Twitch OAuth Application Credentials
# Register your app at: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID="your_twitch_client_id"
TWITCH_CLIENT_SECRET="your_twitch_client_secret"

# The public URL of your deployed app (no trailing slash) — used for Twitch OAuth callback
# Local dev: http://localhost:4000
# Production: https://koboverlay.onrender.com
APP_URL="http://localhost:4000"

# The URL of the React client app — used to redirect the user after login
# Local dev: http://localhost:5173 (Vite dev server)
# Production: same as APP_URL (Express serves the built client)
CLIENT_URL="http://localhost:5173"
